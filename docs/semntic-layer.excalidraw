      "width": 451.3507286862625,
      "height": 32.999023437499915,
      "fontSize": 13.199609374999966,
      "fontFamily": 6,
      "text": "WHY: Tell the AI agent what tables mean, what columns do, and how\n they relate to each other",
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#1e88e5",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 4,
      "version": 460,
      "versionNonce": 1324216728,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774459331289,
      "link": null,
      "locked": false,
      "index": "a3",
      "angle": 0,
      "containerId": null,
      "originalText": "WHY: Tell the AI agent what tables mean, what columns do, and how\n they relate to each other",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "input-content",
      "type": "text",
      "x": 110,
      "y": 236.11328125,
      "width": 766.5370052190837,
      "height": 219.83203124999997,
      "fontSize": 10.991601562499984,
      "fontFamily": 3,
      "text": "workloads/financial_portfolios/config/semantic.yaml\n\ntables:\n  - name: positions\n    type: fact\n    grain: \"one row per position per date\"\n    columns:\n      - name: market_value\n        role: measure              # AI knows this is a number to aggregate\n        default_aggregation: sum   # AI knows to use SUM()\n        business_terms:\n          - Market Value           # AI understands synonyms\n          - AUM\n          - Assets Under Management\n      - name: portfolio_id\n        role: dimension            # AI knows this is for grouping\n        is_foreign_key: true       # AI knows this joins to another table\n    relationships:\n      - target_table: portfolios\n        join_column: portfolio_id  # AI auto-generates JOIN ON clause",
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 5,
      "version": 296,
      "versionNonce": 1915665048,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1774457909490,
      "link": null,
      "locked": false,
      "index": "a4",
      "angle": 0,
      "containerId": null,
      "originalText": "workloads/financial_portfolios/config/semantic.yaml\n\ntables:\n  - name: positions\n    type: fact\n    grain: \"one row per position per date\"\n    columns:\n      - name: market_value\n        role: measure              # AI knows this is a number to aggregate\n        default_aggregation: sum   # AI knows to use SUM()\n        business_terms:\n          - Market Value           # AI understands synonyms\n          - AUM\n          - Assets Under Management\n      - name: portfolio_id\n        role: dimension            # AI knows this is for grouping\n        is_foreign_key: true       # AI knows this joins to another table\n    relationships:\n      - target_table: portfolios\n        join_column: portfolio_id  # AI auto-generates JOIN ON clause",
      "autoResize": false,
      "lineHeight": 1
    },
