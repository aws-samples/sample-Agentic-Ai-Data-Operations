    {
      "id": "t_data_onboarding",
      "type": "text",
      "x": 415,
      "y": 90,
      "width": 240,
      "height": 160,
      "text": "📊  Data Onboarding\n       Agent\n\nRuns: Per data source\n\nCreates:\n• Bronze→Silver→Gold\n• Glue jobs, DAG\n• Quality checks\n• Lake Formation tags\n• Spawns 4 sub-agents",
      "fontSize": 15,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
