    {
      "id": "t_mcp_layer",
      "type": "text",
      "x": 90,
      "y": 310,
      "width": 1215,
      "height": 100,
      "text": "MCP LAYER — SET UP FIRST (before any agent)\n\nLocal Mode: .mcp.json | stdio | 13 servers on laptop    OR    Gateway Mode: .mcp.gateway.json | SSE | Agentcore Gateway\n\nREQUIRED: glue-athena, lakeformation, iam  |  WARN: cloudtrail, redshift, core, s3-tables, pii-detection\nOPTIONAL: sagemaker-catalog, lambda, cloudwatch, cost-explorer, dynamodb",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "r_mcp_layer",
      "originalText": "MCP LAYER — SET UP FIRST (before any agent)\n\nLocal Mode: .mcp.json | stdio | 13 servers on laptop    OR    Gateway Mode: .mcp.gateway.json | SSE | Agentcore Gateway\n\nREQUIRED: glue-athena, lakeformation, iam  |  WARN: cloudtrail, redshift, core, s3-tables, pii-detection\nOPTIONAL: sagemaker-catalog, lambda, cloudwatch, cost-explorer, dynamodb",
      "lineHeight": 1.25,
