    {
      "id": "t_aws_services",
      "type": "text",
      "x": 90,
      "y": 470,
      "width": 1215,
      "height": 100,
      "text": "AWS SERVICES\n\nS3 + S3 Tables (Bronze/Silver/Gold) | AWS Glue (ETL, Data Catalog) | Amazon Athena (SQL queries) | Apache Iceberg (ACID, time-travel)\nLake Formation (LF-Tags, TBAC) | KMS (encryption) | MWAA (Airflow) | SageMaker Catalog (business metadata) | SynoDB (metrics & SQL)\nQuickSight (dashboards) | CloudTrail (audit) | CloudWatch (monitoring) | Cost Explorer (optimization)",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "r_aws_services",
      "originalText": "AWS SERVICES\n\nS3 + S3 Tables (Bronze/Silver/Gold) | AWS Glue (ETL, Data Catalog) | Amazon Athena (SQL queries) | Apache Iceberg (ACID, time-travel)\nLake Formation (LF-Tags, TBAC) | KMS (encryption) | MWAA (Airflow) | SageMaker Catalog (business metadata) | SynoDB (metrics & SQL)\nQuickSight (dashboards) | CloudTrail (audit) | CloudWatch (monitoring) | Cost Explorer (optimization)",
